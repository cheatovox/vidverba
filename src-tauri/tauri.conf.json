{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VidVerba",
  "version": "0.1.0",
  "identifier": "com.vidverba.desktop",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VidVerba",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

